# คัดลอกไฟล์นี้เป็นชื่อ .env แล้วใส่ค่าจริงของคุณ

# หาได้จาก LINE Developers Console > Messaging API channel ของคุณ
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# หาได้ฟรีจาก https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ปกติไม่ต้องแก้ ปล่อยให้ hosting กำหนดให้เอง
PORT=3000
